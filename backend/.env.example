# Cloudflare R2 — image storage for wardrobe sync
CLOUDFLARE_R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_URL=https://your-cdn-domain.com

# Public URL of this backend (used for local-disk image fallback)
API_BASE_URL=http://192.168.29.193:8000

# Auth
JWT_SECRET=change-me-in-production

# Optional: PostgreSQL (defaults to SQLite)
# DATABASE_URL=postgresql://...
